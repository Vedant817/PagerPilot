# PagerDuty
PAGERDUTY_API_KEY=
PAGERDUTY_FROM_EMAIL=
PAGERDUTY_BASE_URL=https://api.pagerduty.com

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com
DATADOG_MONITOR_TAGS=
DATADOG_METRIC_QUERIES={"payment-api":["avg:request.error.rate{service:payment-api}","p99:request.latency{service:payment-api}"],"checkout-service":["p99:request.latency{service:checkout-service}","avg:request.error.rate{service:checkout-service}"],"user-service":["avg:db.connections.active{service:user-service}","avg:db.connections.waiting{service:user-service}"],"notification-service":["avg:deploy.health.failed{service:notification-service}","avg:request.error.rate{service:notification-service}"]}

# GitHub
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com

# StatusGator
STATUSGATOR_API_KEY=
STATUSGATOR_BASE_URL=https://api.statusgator.com/v2

# Service topology
SERVICE_OWNER_MAP={"payment-api":"yourorg/payment-api","checkout-service":"yourorg/checkout-service","user-service":"yourorg/user-service","notification-service":"yourorg/notification-service"}

EXTERNAL_DEPENDENCY_MAP={"payment-api":["stripe"],"checkout-service":["stripe","aws-us-east-1"],"user-service":["aws-us-east-1"],"notification-service":["datadog"]}

SERVICE_DEPENDENCY_GRAPH={"payment-api":{"downstream":["checkout-service","notification-service"],"endpoints":["/charge","/refund","/webhook"],"customer_facing":true},"checkout-service":{"downstream":["notification-service"],"endpoints":["/checkout","/cart","/pricing"],"customer_facing":true},"user-service":{"downstream":["payment-api","checkout-service","notification-service"],"endpoints":["/login","/session","/profile"],"customer_facing":true},"notification-service":{"downstream":[],"endpoints":["/email","/sms","/webhook"],"customer_facing":false}}

# Analysis configuration
ANALYSIS_RULES={"payment-api":{"error_keywords":["error","fault","exception","fail"],"latency_keywords":["latency","p99","p95","response_time"],"db_keywords":["db.connections","database","connection_pool","pg_stat"],"deploy_keywords":["deploy","health","canary","rollout"]}}

BLAST_RADIUS_MAP={"deploy":60,"regression":60,"dependency":80,"third-party":80,"database":40,"capacity":40,"default":20}

# Session management
SESSION_MAX_AGE_SECONDS=86400
SESSION_MAX_LOGS=500
SESSION_MAX_SESSIONS=1000
